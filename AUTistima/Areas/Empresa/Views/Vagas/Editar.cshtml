@model AUTistima.Models.InclusiveJob
@{
    ViewData["Title"] = "Editar Vaga";
}

<div class="container py-4" style="max-width: 720px;">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted small">
            <i class="bi bi-chevron-left me-1"></i>Vagas Inclusivas
        </a>
        <h1 class="h3 mt-2"><i class="bi bi-pencil me-2"></i>Editar Vaga</h1>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="Editar" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="Titulo" class="form-label fw-semibold">Título da vaga *</label>
                    <input asp-for="Titulo" class="form-control" />
                    <span asp-validation-for="Titulo" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Descricao" class="form-label fw-semibold">Descrição da vaga *</label>
                    <textarea asp-for="Descricao" class="form-control" rows="5"></textarea>
                    <span asp-validation-for="Descricao" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Acomodacoes" class="form-label fw-semibold">Acomodações e adaptações</label>
                    <textarea asp-for="Acomodacoes" class="form-control" rows="3"></textarea>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Localizacao" class="form-label fw-semibold">Localização</label>
                        <input asp-for="Localizacao" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Regime" class="form-label fw-semibold">Regime</label>
                        <select asp-for="Regime" class="form-select">
                            <option value="">Selecione...</option>
                            <option>CLT</option>
                            <option>PJ</option>
                            <option>Temporário</option>
                            <option>Estágio</option>
                            <option>Jovem Aprendiz</option>
                        </select>
                    </div>
                </div>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="SalarioMin" class="form-label fw-semibold">Salário mínimo (R$)</label>
                        <input asp-for="SalarioMin" type="number" step="100" min="0" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SalarioMax" class="form-label fw-semibold">Salário máximo (R$)</label>
                        <input asp-for="SalarioMax" type="number" step="100" min="0" class="form-control" />
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-salmon">
                        <i class="bi bi-check-lg me-1"></i>Salvar alterações
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
