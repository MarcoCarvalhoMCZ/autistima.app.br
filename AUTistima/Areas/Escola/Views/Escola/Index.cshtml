@model AUTistima.Models.ApplicationUser
@{
    ViewData["Title"] = "Painel da Escola";
    var escola = ViewBag.Escola as AUTistima.Models.School;
    var ultimosRegistros = ViewBag.UltimosRegistros as IEnumerable<AUTistima.Models.RegistroEstudante>;
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h1 class="h3 mb-1">
            <i class="bi bi-building-check me-2 text-salmon"></i>
            Painel da Escola
        </h1>
        @if (escola != null)
        {
            <p class="text-muted mb-0">@escola.Nome — @escola.Cidade/@escola.Estado</p>
        }
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (escola == null)
    {
        <div class="alert alert-warning d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 fs-5"></i>
            <div>
                <strong>Escola não vinculada.</strong> Seu perfil ainda não foi associado a uma escola.
                Entre em contato com o administrador para que ele vincule seu usuário a uma unidade escolar.
            </div>
        </div>
    }

    @if (TempData["SenhaMae"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <strong><i class="bi bi-key me-2"></i>Conta criada para o responsável</strong><br>
            E-mail: <code>@TempData["EmailMae"]</code><br>
            Senha temporária: <code>@TempData["SenhaMae"]</code><br>
            <small>Repasse essas informações ao responsável para o primeiro acesso.</small>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Cards resumo -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="display-6 text-salmon fw-bold">@ViewBag.TotalEstudantes</div>
                <div class="text-muted small mt-1"><i class="bi bi-people me-1"></i>Estudantes</div>
                <a asp-action="MeusEstudantes" class="stretched-link"></a>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="display-6 text-primary fw-bold">@ViewBag.TotalRegistros</div>
                <div class="text-muted small mt-1"><i class="bi bi-journal-text me-1"></i>Registros</div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm text-center py-3">
                <div class="display-6 text-warning fw-bold">@ViewBag.SolicitacoesPendentes</div>
                <div class="text-muted small mt-1"><i class="bi bi-person-lock me-1"></i>Acessos Pendentes</div>
            </div>
        </div>
    </div>

    <!-- Ações rápidas -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6">
            <a asp-action="CadastrarEstudante" class="btn btn-salmon w-100 py-3">
                <i class="bi bi-person-plus-fill me-2"></i>Cadastrar Novo Estudante
            </a>
        </div>
        <div class="col-12 col-md-6">
            <a asp-action="MeusEstudantes" class="btn btn-outline-primary w-100 py-3">
                <i class="bi bi-people me-2"></i>Ver Todos os Estudantes
            </a>
        </div>
    </div>

    <!-- Últimos registros -->
    @if (ultimosRegistros != null && ultimosRegistros.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-clock-history me-2"></i>Últimos Registros
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var r in ultimosRegistros)
                {
                    <li class="list-group-item px-3 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong class="small">@r.Estudante?.Nome</strong>
                                <span class="badge bg-light text-dark ms-1">@r.TipoRegistro</span>
                                <div class="text-muted small">@r.Titulo</div>
                            </div>
                            <small class="text-muted">@r.DataRegistro.ToString("dd/MM/yyyy")</small>
                        </div>
                    </li>
                }
            </ul>
        </div>
    }
</div>
