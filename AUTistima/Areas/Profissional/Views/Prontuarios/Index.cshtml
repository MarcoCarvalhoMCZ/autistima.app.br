@model IEnumerable<AUTistima.Models.SolicitacaoAcessoPerfil>
@{
    ViewData["Title"] = "Prontuários de Estudantes";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0"><i class="bi bi-journal-medical me-2"></i>Prontuários</h1>
            <small class="text-muted">Estudantes cujo acesso foi aprovado</small>
        </div>
        <a asp-action="SolicitarAcesso" class="btn btn-salmon">
            <i class="bi bi-person-plus me-2"></i>Solicitar Acesso
        </a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Sucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5 text-muted">
                <i class="bi bi-folder2 display-4 d-block mb-3"></i>
                <p>Nenhum prontuário disponível ainda.</p>
                <a asp-action="SolicitarAcesso" class="btn btn-salmon">Solicitar Acesso a um Estudante</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var s in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <strong>@s.Estudante?.Nome</strong>
                                <code class="text-muted small">@s.Estudante?.CodigoUnico</code>
                            </div>
                            <div class="text-muted small mt-1">
                                @(s.Estudante?.Escola?.Nome ?? "Escola não vinculada")
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <a asp-action="VerProntuario" asp-route-id="@s.ChildId"
                               class="btn btn-sm btn-outline-primary w-100">
                                <i class="bi bi-folder2-open me-1"></i>Abrir Prontuário
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
