@model List<AUTistima.Models.Report>
@using AUTistima.Models.Enums
@{
    ViewData["Title"] = "Moderação";
    var statusFiltro = ViewBag.StatusFiltro as StatusModeracao?;
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0"><i class="bi bi-flag me-2 text-warning"></i>Moderação de Conteúdo</h1>
            <small class="text-muted">@Model.Count denúncia(s)</small>
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Sucesso"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <!-- Filtros -->
    <div class="d-flex gap-2 mb-4 flex-wrap">
        <a asp-action="Index" class="btn btn-@(statusFiltro == null ? "primary" : "outline-secondary") btn-sm">Todas</a>
        <a asp-action="Index" asp-route-status="@StatusModeracao.Pendente" class="btn btn-@(statusFiltro == StatusModeracao.Pendente ? "warning" : "outline-secondary") btn-sm">Pendentes</a>
        <a asp-action="Index" asp-route-status="@StatusModeracao.EmAnalise" class="btn btn-@(statusFiltro == StatusModeracao.EmAnalise ? "info" : "outline-secondary") btn-sm">Em análise</a>
        <a asp-action="Index" asp-route-status="@StatusModeracao.Resolvido" class="btn btn-@(statusFiltro == StatusModeracao.Resolvido ? "success" : "outline-secondary") btn-sm">Resolvidas</a>
        <a asp-action="Index" asp-route-status="@StatusModeracao.Arquivado" class="btn btn-@(statusFiltro == StatusModeracao.Arquivado ? "secondary" : "outline-secondary") btn-sm">Arquivadas</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-flag display-4 mb-3 d-block"></i>
            <p>Nenhuma denúncia encontrada.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Data</th>
                            <th>Tipo</th>
                            <th>ID</th>
                            <th>Denunciante</th>
                            <th>Motivo</th>
                            <th>Status</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            var statusBadge = r.Status switch {
                                StatusModeracao.Pendente => "bg-warning text-dark",
                                StatusModeracao.EmAnalise => "bg-info text-dark",
                                StatusModeracao.Resolvido => "bg-success",
                                StatusModeracao.Arquivado => "bg-secondary",
                                _ => "bg-secondary"
                            };
                            <tr>
                                <td class="small">@r.Id</td>
                                <td class="small text-nowrap">@r.CriadoEm.ToString("dd/MM/yy")</td>
                                <td><span class="badge bg-light text-dark small">@r.TargetType</span></td>
                                <td class="small">@r.TargetId</td>
                                <td class="small text-muted">@(r.Denunciante?.NomeCompleto ?? r.ReporterId)</td>
                                <td class="small" style="max-width:200px;">@r.Motivo</td>
                                <td><span class="badge @statusBadge small">@r.Status</span></td>
                                <td>
                                    @if (r.Status == StatusModeracao.Pendente || r.Status == StatusModeracao.EmAnalise)
                                    {
                                        <div class="d-flex gap-1">
                                            <form asp-action="Resolver" asp-route-id="@r.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="acao" value="resolver" />
                                                <input type="hidden" name="removerConteudo" value="true" />
                                                <button type="submit" class="btn btn-danger btn-sm"
                                                        onclick="return confirm('Resolver e REMOVER conteúdo denunciado?')"
                                                        title="Resolver e remover">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                            <form asp-action="Resolver" asp-route-id="@r.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="acao" value="resolver" />
                                                <button type="submit" class="btn btn-success btn-sm" title="Resolver sem remover">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>
                                            </form>
                                            <form asp-action="Resolver" asp-route-id="@r.Id" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="acao" value="arquivar" />
                                                <button type="submit" class="btn btn-outline-secondary btn-sm" title="Arquivar">
                                                    <i class="bi bi-archive"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@r.ResolvidoEm?.ToString("dd/MM/yy")</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
