@model AUTistima.Models.ServiceRequest
@{
    ViewData["Title"] = "Solicitar Atendimento";
    var servicos = ViewBag.Servicos as List<AUTistima.Models.Service> ?? new();
    var filhos = ViewBag.Filhos as List<AUTistima.Models.Child> ?? new();
    int? serviceIdPreSelecionado = ViewBag.ServiceIdPreSelecionado;
}

<div class="container py-4" style="max-width: 640px;">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted small">
            <i class="bi bi-chevron-left me-1"></i>Minhas Solicitações
        </a>
        <h1 class="h3 mt-2"><i class="bi bi-calendar2-plus me-2 text-salmon"></i>Solicitar Atendimento</h1>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="Solicitar" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold">Serviço</label>
                    <select name="ServiceId" class="form-select">
                        <option value="">Selecione um serviço (opcional)</option>
                        @foreach (var s in servicos)
                        {
                            if (serviceIdPreSelecionado == s.Id) {
                                <option value="@s.Id" selected>@s.NomeProfissional</option>
                            } else {
                                <option value="@s.Id">@s.NomeProfissional</option>
                            }
                        }
                    </select>
                </div>

                @if (filhos.Any())
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Para qual filho(a)?</label>
                        <select name="ChildId" class="form-select">
                            <option value="">Para mim</option>
                            @foreach (var f in filhos)
                            {
                                <option value="@f.Id">@f.Nome</option>
                            }
                        </select>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-semibold">Descreva sua necessidade *</label>
                    <textarea name="Observacoes" class="form-control" rows="5"
                              placeholder="Descreva o motivo da solicitação, urgência e qualquer informação relevante..."
                              required maxlength="1000"></textarea>
                    <div class="form-text">Máx. 1000 caracteres.</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Prioridade</label>
                    <select name="Prioridade" class="form-select">
                        <option value="1">Normal</option>
                        <option value="2">Alta — necessidade urgente</option>
                        <option value="3">Crítica — emergência</option>
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-salmon">
                        <i class="bi bi-send me-1"></i>Enviar Solicitação
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
