@{
    ViewData["Title"] = "Solicitar Exclusão de Dados";
}

<div class="container py-4" style="max-width: 600px;">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted small">
            <i class="bi bi-chevron-left me-1"></i>Voltar
        </a>
        <h1 class="h3 mt-2"><i class="bi bi-trash me-2 text-danger"></i>Solicitar Exclusão de Dados</h1>
        <p class="text-muted small">Ao confirmar, nossa equipe irá processar a exclusão ou anonimização dos seus dados pessoais conforme a LGPD (Art. 18, VI).</p>
    </div>

    <div class="alert alert-warning small">
        <i class="bi bi-exclamation-triangle me-2"></i>
        <strong>Atenção:</strong> A exclusão é irreversível. Dados relacionados ao acesso a serviços de saúde e histórico de atendimentos podem ser mantidos por obrigação legal.
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="SolicitarExclusao" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold">Motivo da solicitação <span class="text-muted fw-normal">(opcional)</span></label>
                    <textarea name="motivo" class="form-control" rows="4"
                              placeholder="Descreva o motivo da sua solicitação de exclusão de dados..."></textarea>
                </div>
                <div class="form-check mb-3">
                    <input type="checkbox" class="form-check-input" id="confirmCheck" required>
                    <label class="form-check-label small" for="confirmCheck">
                        Entendo que minha conta e dados pessoais serão excluídos ou anonimizados de forma irreversível.
                    </label>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Confirmar solicitação
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
