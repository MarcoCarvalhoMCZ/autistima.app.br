@model AUTistima.Models.SafetyPlan?
@{
    ViewData["Title"] = "Segurança Familiar";
    var contatos = ViewBag.Contatos as List<AUTistima.Models.EmergencyContact> ?? new();
    var tiposContato = new[] { "Familiar", "Amigo", "Médico", "Terapeuta", "CAPS", "UBS", "Escola", "Vizinho", "Outro" };
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0"><i class="bi bi-shield-heart me-2 text-salmon"></i>Segurança Familiar</h1>
            <small class="text-muted">Plano de segurança e contatos de emergência</small>
        </div>
        <a asp-action="EditarPlano" class="btn btn-outline-salmon btn-sm">
            <i class="bi bi-pencil me-1"></i>Editar Plano
        </a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Sucesso"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show">@TempData["Erro"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="row g-4">
        <!-- Plano de Segurança -->
        <div class="col-md-7">
            @if (Model == null)
            {
                <div class="card border-0 shadow-sm text-center py-4">
                    <div class="card-body">
                        <i class="bi bi-shield-plus display-4 text-muted mb-3 d-block"></i>
                        <h5>Crie seu plano de segurança</h5>
                        <p class="text-muted small">Um plano de segurança ajuda a identificar sinais de crise e ter estratégias prontas para momentos difíceis.</p>
                        <a asp-action="EditarPlano" class="btn btn-salmon">Criar Plano</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent">
                        <h5 class="mb-0"><i class="bi bi-file-text me-2"></i>Plano de Segurança</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.SinaisAlerta))
                        {
                            <div class="mb-3">
                                <h6 class="text-danger small"><i class="bi bi-exclamation-triangle me-1"></i>Sinais de Alerta</h6>
                                <p class="small text-muted">@Model.SinaisAlerta</p>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.EstrategiasDesescalada))
                        {
                            <div class="mb-3">
                                <h6 class="text-warning small"><i class="bi bi-lightbulb me-1"></i>Estratégias de Desescalada</h6>
                                <p class="small text-muted">@Model.EstrategiasDesescalada</p>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.RecursosLocais))
                        {
                            <div class="mb-3">
                                <h6 class="text-info small"><i class="bi bi-building me-1"></i>Recursos Locais</h6>
                                <p class="small text-muted">@Model.RecursosLocais</p>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.PlanoAposIntervencao))
                        {
                            <div class="mb-3">
                                <h6 class="text-success small"><i class="bi bi-check2-circle me-1"></i>Plano Pós-Intervenção</h6>
                                <p class="small text-muted">@Model.PlanoAposIntervencao</p>
                            </div>
                        }
                        <div class="text-muted small mt-2">
                            Atualizado em @Model.AtualizadoEm.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Contatos de Emergência -->
        <div class="col-md-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent">
                    <h5 class="mb-0"><i class="bi bi-telephone-forward me-2"></i>Contatos de Emergência</h5>
                </div>
                <div class="card-body">
                    @foreach (var c in contatos)
                    {
                        <div class="d-flex align-items-start justify-content-between mb-3 pb-2 border-bottom">
                            <div>
                                <div class="fw-semibold small">@c.Nome</div>
                                <div class="text-muted small">
                                    <i class="bi bi-telephone me-1"></i>
                                    <a href="tel:@c.Telefone" class="text-decoration-none text-muted">@c.Telefone</a>
                                </div>
                                <span class="badge bg-light text-dark x-small">@c.Tipo</span>
                                @if (!string.IsNullOrEmpty(c.Observacoes))
                                {
                                    <div class="text-muted x-small mt-1">@c.Observacoes</div>
                                }
                            </div>
                            <form asp-action="RemoverContato" asp-route-id="@c.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-link btn-sm text-danger p-0">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    }

                    <!-- Formulário de adicionar contato -->
                    <div class="mt-3">
                        <h6 class="small fw-semibold mb-2"><i class="bi bi-plus-circle me-1"></i>Adicionar Contato</h6>
                        <form asp-action="AdicionarContato" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-2">
                                <input type="text" name="nome" class="form-control form-control-sm" placeholder="Nome *" required />
                            </div>
                            <div class="mb-2">
                                <input type="tel" name="telefone" class="form-control form-control-sm" placeholder="Telefone *" required />
                            </div>
                            <div class="mb-2">
                                <select name="tipo" class="form-select form-select-sm">
                                    @foreach (var t in tiposContato)
                                    {
                                        <option value="@t">@t</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-2">
                                <input type="text" name="observacoes" class="form-control form-control-sm" placeholder="Observações" />
                            </div>
                            <button type="submit" class="btn btn-salmon btn-sm w-100">
                                <i class="bi bi-person-plus me-1"></i>Adicionar
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
