@model List<AUTistima.Models.ChildCarePlan>
@{
    ViewData["Title"] = "Planos de Cuidado";
    var filhos = ViewBag.Filhos as List<AUTistima.Models.Child> ?? new();
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0"><i class="bi bi-journal-medical me-2 text-salmon"></i>Planos de Cuidado</h1>
            <small class="text-muted">Planos individuais e lembretes para cada filho(a)</small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Lembretes" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-alarm me-1"></i>Lembretes
            </a>
        </div>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Sucesso"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    @if (!filhos.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>Cadastre um filho(a) primeiro para criar planos de cuidado.
            <a asp-controller="Filhos" asp-action="Index" asp-area="" class="alert-link ms-2">Cadastrar filho(a)</a>
        </div>
    }
    else
    {
        <div class="row g-2 mb-4">
            @foreach (var filho in filhos)
            {
                <div class="col-auto">
                    <a asp-action="Criar" asp-route-childId="@filho.Id" class="btn btn-outline-salmon btn-sm">
                        <i class="bi bi-plus-circle me-1"></i>Novo plano — @filho.Nome
                    </a>
                </div>
            }
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-journal-plus display-4 mb-3 d-block"></i>
            <p>Nenhum plano de cuidado criado ainda.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var plano in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-start justify-content-between mb-2">
                                <span class="badge bg-salmon-subtle text-salmon">@plano.Filho?.Nome</span>
                                <a asp-action="Editar" asp-route-id="@plano.Id" class="btn btn-link btn-sm p-0">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                            <h5 class="card-title fs-6">@plano.Titulo</h5>
                            @if (!string.IsNullOrEmpty(plano.Objetivos))
                            {
                                <p class="card-text small text-muted">@(plano.Objetivos.Length > 120 ? plano.Objetivos[..120] + "…" : plano.Objetivos)</p>
                            }
                            @if (!string.IsNullOrEmpty(plano.Terapias))
                            {
                                <div class="small text-muted mb-2"><i class="bi bi-heart-pulse me-1"></i>@plano.Terapias</div>
                            }
                            @if (plano.DataRevisao.HasValue)
                            {
                                <div class="small @(plano.DataRevisao < DateTime.Today ? "text-danger" : "text-muted")">
                                    <i class="bi bi-calendar-check me-1"></i>Revisão: @plano.DataRevisao.Value.ToString("dd/MM/yyyy")
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-transparent border-0 pt-0">
                            <a asp-action="Progresso" asp-route-childId="@plano.ChildId" class="btn btn-outline-primary btn-sm w-100">
                                <i class="bi bi-graph-up me-1"></i>Ver Progresso
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
